{
  "name": "dyslexiaid-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "copy-webgazer": "node -e \"require('fs').copyFileSync('node_modules/webgazer/dist/webgazer.js', 'public/webgazer.js')\"",
    "predev": "npm run copy-webgazer",
    "prebuild": "npm run copy-webgazer",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "autoprefixer": "^10.5.0",
    "groq-sdk": "^0.7.0",
    "next": "15.3.1",
    "openai": "^4.52.0",
    "postcss": "^8.5.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-pdf": "^9.1.0",
    "tailwindcss": "^3.4.19",
    "webgazer": "^2.1.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/aria-query": "^5.0.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "jsdom": "^24.1.0",
    "vitest": "^1.6.0"
  }
}
